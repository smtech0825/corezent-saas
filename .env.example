# ============================================================
# CoreZent SaaS - 환경 변수 예시
# 이 파일을 복사해서 .env.local 로 저장 후 실제 값으로 교체하세요.
# .env.local 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Lemon Squeezy ────────────────────────────────────────────
# Lemon Squeezy 대시보드 → Settings → API → API keys
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here

# Lemon Squeezy 대시보드 → Settings → Webhooks → Signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret_here

# Lemon Squeezy 대시보드 → Settings → Stores → Store ID (숫자)
LEMONSQUEEZY_STORE_ID=12345

# ── Google Sheets (라이선스 자동 기입) ───────────────────────
# Google Cloud → Service Account → 키 다운로드(JSON)에서 추출
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# 스프레드시트 URL의 /d/{ID}/ 부분
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# 시트 하단 탭 이름 (정확히 일치해야 함)
GOOGLE_SHEETS_TAB_NAME=라이선스 관리 시스템 구축 프롬프트

# ── 애플리케이션 ──────────────────────────────────────────────
APP_ENV=development
NEXT_PUBLIC_APP_URL=https://www.corezent.com
