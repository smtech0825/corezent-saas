# ============================================================
# CoreZent SaaS - 환경 변수 예시
# 이 파일을 복사해서 .env 로 저장 후 실제 값으로 교체하세요.
# .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# API 설정
API_BASE_URL=https://api.corezent.com/v1
API_TIMEOUT_MS=10000

# 결제 게이트웨이 (아임포트/포트원)
PAYMENT_IMP_CODE=imp_xxxxxxxxxxxxxxxx

# 애플리케이션 환경
APP_ENV=development

# 기타 (필요 시 추가)
# SUPPORT_EMAIL=support@corezent.com
